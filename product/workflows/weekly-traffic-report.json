    {
      "id": "wkly-combine",
      "name": "Build Weekly Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        0
      ],
      "parameters": {
        "jsCode": "\nconst tha = $('THA Aggregate').item.json;\nconst eik = $('EIK Aggregate').item.json;\nconst thb = $('THB Aggregate').item.json;\nconst sites = [tha, eik, thb];\n\nconst now = new Date();\nconst weekNum = Math.ceil((now - new Date(now.getFullYear(), 0, 1)) / (7 * 24 * 3600 * 1000));\nconst fmt = (n) => Number(n).toLocaleString('sv-SE');\nconst pct = (d) => (d >= 0 ? '+' : '') + d + '%';\nconst bar = (d) => d >= 10 ? '🟢' : d >= 0 ? '🟡' : '🔴';\n\nlet msg = `📈 <b>Veckans trafikrapport – v.${weekNum}</b>\\n`;\nmsg += '━'.repeat(28) + '\\n\\n';\n\nfor (const s of sites) {\n  msg += `${s.emoji} <b>${s.site}</b>\\n`;\n  msg += `👥 Besökare: <b>${fmt(s.visitors)}</b> ${bar(s.vDelta)} ${pct(s.vDelta)}\\n`;\n  msg += `📄 Sidvisningar: <b>${fmt(s.pageviews)}</b> ${bar(s.pvDelta)} ${pct(s.pvDelta)}\\n`;\n  msg += `\\n🔥 Top sidor:\\n${s.topPages}\\n`;\n  msg += '\\n';\n}\n\nmsg += '━'.repeat(28) + '\\n';\nmsg += '📊 <i>Jämfört med föregående vecka</i>';\n\nreturn { json: { telegramText: msg } };"
      }
    },
