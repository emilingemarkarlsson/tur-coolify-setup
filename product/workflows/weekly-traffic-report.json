      ],
      "parameters": {
        "jsCode": "const cur  = $('EIK Stats This Week').item.json;\nconst prev = $('EIK Stats Last Week').item.json;\nconst pages = $('EIK Top Pages').item.json;\nconst v_cur = cur.visitors?.value || 0;\nconst v_prev = prev.visitors?.value || 1;\nconst pv_cur = cur.pageviews?.value || 0;\nconst pv_prev = prev.pageviews?.value || 1;\nconst vDelta  = v_prev > 0 ? Math.round((v_cur - v_prev) / v_prev * 100) : 0;\nconst pvDelta = pv_prev > 0 ? Math.round((pv_cur - pv_prev) / pv_prev * 100) : 0;\nconst topPages = (Array.isArray(pages) ? pages : []).slice(0,3).map(p => `  • ${p.x}: ${p.y}`).join('\\n') || '  Ingen data';\nconst arrow = d => d >= 0 ? '▲' : '▼';\nreturn { json: { site: 'emilingemarkarlsson.com', emoji: '👨‍💻',\n  visitors: v_cur, vDelta, pageviews: pv_cur, pvDelta, topPages, arrow } };"
