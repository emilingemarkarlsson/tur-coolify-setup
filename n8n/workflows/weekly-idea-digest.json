    {
      "id": "n6",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "let hnTitles = [];\nlet raiTitles = [];\nlet rhTitles = [];\ntry {\n  const hn = $('Fetch HN').first().json;\n  hnTitles = (hn.hits || []).slice(0,20).map(h => h.title).filter(Boolean);\n} catch(e) {}\ntry {\n  const r = $('Fetch Reddit AI').first().json;\n  raiTitles = ((r.data && r.data.children) ? r.data.children : []).slice(0,15).map(c => (c.data && c.data.title) ? c.data.title : '').filter(Boolean);\n} catch(e) {}\ntry {\n  const r = $('Fetch Reddit Hockey').first().json;\n  rhTitles = ((r.data && r.data.children) ? r.data.children : []).slice(0,10).map(c => (c.data && c.data.title) ? c.data.title : '').filter(Boolean);\n} catch(e) {}\n\nconst today = new Date().toLocaleDateString('sv-SE');\n\nconst systemPrompt = 'Du är en startup-analytiker för ett AI-venture bolag. Grundaren har djup expertis inom: 1) Hockey analytics, NHL-data och sportanalys 2) B2B-försäljning av trädgårds- och friluftsprodukter 3) AI-agenter, autonoma system och agentic UX. Fokusera på agentic systems som ersätter mänskliga arbetsflöden, UX-paradigmskiftet bort från point-and-click mot röst/agent/push, och produkter som kan byggas som MVP på 2-4 veckor.';\n\nconst lines = [];\nlines.push('VECKANS TRENDER (' + today + '):');\nlines.push('');\nlines.push('## HackerNews Top Stories:');\nhnTitles.forEach(function(t,i){ lines.push((i+1)+'. '+t); });\nlines.push('');\nlines.push('## Reddit AI/ML:');\nraiTitles.forEach(function(t,i){ lines.push((i+1)+'. '+t); });\nlines.push('');\nlines.push('## Reddit Hockey:');\nrhTitles.forEach(function(t,i){ lines.push((i+1)+'. '+t); });\nlines.push('');\nlines.push('Generera exakt 5 konkreta affärsidéer. Minst 2 ska koppla till hockey/sport, minst 1 till B2B trädgård, minst 2 till agentic AI.');\nlines.push('');\nlines.push('För varje idé, använd EXAKT detta format (HTML-taggar för Telegram):');\nlines.push('');\nlines.push('💡 [domän-emoji] <b>[Idétitel]</b>');\nlines.push('<b>Problem:</b> (1 mening)');\nlines.push('<b>Lösning:</b> (2-3 meningar, konkret)');\nlines.push('<b>Kund:</b> (vem betalar, uppskattad storlek)');\nlines.push('<b>Revenue:</b> (SaaS/engång/provision och storleksordning)');\nlines.push('<b>MVP 2-4v:</b> (minsta byggbart)');\nlines.push('---');\n\nconst userPrompt = lines.join('\\n');\nreturn [{ json: { systemPrompt, userPrompt } }];"
      }
    },
    {
      "id": "n7",
      "name": "Generate Ideas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
