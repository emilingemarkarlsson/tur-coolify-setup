      "parameters": {
        "jsCode": "// Extract slug and keyword from URL query params\nconst query = $input.item.json.query || {};\nconst slug = query.slug || '';\nconst keyword = query.keyword || '';\nconst action = query.action || '';\n\nif (!slug) {\n  throw new Error('No slug provided in URL parameters');\n}\n\nreturn {\n  slug: slug,\n  keyword: keyword,\n  action: action\n};"
      },
