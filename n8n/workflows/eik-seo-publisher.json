    {
      "parameters": {
        "jsCode": "// Read text content from S3 download\nconst binary = $input.item.binary?.data;\nconst keyword  = $('Extract Slug from Command').item.json.keyword;\nconst slug     = $('Extract Slug from Command').item.json.slug;\nconst filename = $('Extract Slug from Command').item.json.filename;\n\nif (!binary) throw new Error('No binary data from Minio download');\n// S3 node returns base64 in binary.data.data\nconst base64Content = binary.data;\nreturn { contentBase64: base64Content, keyword, slug, filename };"
      },
