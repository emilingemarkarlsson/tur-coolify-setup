        },
        "options": {}
      },
      "id": "e79724f1-c1cb-4186-b683-a45c9fbe9cb0",
      "name": "Write to Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        1312,
        192
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "sHynNC5opA9jCQYo",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "id": "eik-kw-agg",
      "name": "Aggregate Keywords",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst keywords = items.map(i => ({keyword: i.json.keyword, score: i.json.score, rationale: i.json.rationale || ''}));\nreturn [{ json: { keywords, count: keywords.length, savedAt: new Date().toISOString() } }];"
      }
    },
    {
      "id": "eik-kw-s3",
      "name": "Save Keywords to Minio",
      "type": "n8n-nodes-base.s3",
      "typeVersion": 1,
      "position": [
        1100,
        300
      ],
      "credentials": {
        "s3": {
          "id": "HdCw5lSb6jwOHLHd",
          "name": "THA Minio"
        }
      },
      "parameters": {
        "operation": "upload",
        "bucketName": "seo-drafts",
        "fileName": "eik-approved-keywords.json",
        "binaryData": false,
        "fileContent": "={{ JSON.stringify($json.keywords) }}",
        "additionalFields": {}
      }
    },
    {
      "id": "eik-kw-tgbuild",
      "name": "Build Keyword Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "jsCode": "const prev = $('Aggregate Keywords').item.json;\nconst kws = prev.keywords || [];\nconst top5 = kws.slice(0, 5);\nconst lines = top5.map((k, i) => `${i+1}. <b>${k.keyword}</b> (${k.score}/10)`).join('\\n');\nconst text = `📊 <b>EIK Keyword Research – ${prev.count} nyckelord</b>\\n\\n${lines}\\n\\n✅ Sparat till Minio (eik-approved-keywords.json)\\nGeneratorn plockar automatiskt imorgon.`;\nreturn [{ json: { telegramText: text } }];"
      }
    },
    {
