    {
      "parameters": {
        "jsCode": "return $input.all().map(i => ({ keyword: i.json?.title?.toLowerCase() || '' })).filter(k => k.keyword);"
      },
      "id": "7bd4e4ef-eb6c-4d56-82ac-d89a47883abd",
