      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'llama-3.3-70b-versatile', messages: [{ role: 'system', content: 'Score keywords for relevance to Emil Karlsson. Return JSON array with {keyword, score (1-10), rationale} only.' }, { role: 'user', content: 'Keywords: ' + $json.map(x => x.keyword).join(', ') }], temperature: 0.2, max_tokens: 1500 } }}",
        "options": {}
      },
      "id": "1ce28c0e-25aa-4793-897e-08be3f8ee28b",
      "name": "Groq: Score Keywords",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        864,
        -16
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "HnNvhJFUVZo7k5Tp",
          "name": "tha-groqseo"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json;\nlet arr = [];\ntry {\n  const txt = body.choices?.[0]?.message?.content || '[]';\n  arr = JSON.parse(txt);\n} catch (e) {\n  arr = [];\n}\narr = arr.filter(x => x.score >= 7).slice(0, 20);\nreturn arr.map(x => ({ keyword: x.keyword, score: x.score, rationale: x.rationale, status: 'New' }));"
      },
      "id": "a8cc9ef5-6297-4d90-bb3d-48048dda251e",
      "name": "Filter Top Keywords",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
