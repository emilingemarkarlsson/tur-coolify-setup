    {
      "id": "tpr-topic-research-read",
      "name": "Read Used Slugs",
      "type": "n8n-nodes-base.awsS3",
      "typeVersion": 2,
      "position": [
        -180,
        300
      ],
      "continueOnFail": true,
      "credentials": {
        "aws": {
          "id": "HdCw5lSb6jwOHLHd",
          "name": "Minio S3"
        }
      },
      "parameters": {
        "operation": "get",
        "bucketName": "seo-drafts",
        "fileKey": "tpr-used-slugs.json"
      }
    },
    {
      "id": "tpr-topic-research-groq",
      "name": "Generate Topics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        40,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REDACTED_GROQ_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama-3.3-70b-versatile', temperature: 0.9, max_tokens: 2000, messages: [{ role: 'system', content: \"You are a content strategist for The Print Route \\u2014 modern print procurement and supply chain. Generate 30 specific article topics about: print procurement optimization, supply chain for print, vendor management, sustainability in print, digital print workflows, print cost reduction, packaging procurement, large format printing. Be industry-specific and practical.\" + '\\nPreviously used slugs: ' + (function(){ try { return JSON.stringify(JSON.parse($('Read Used Slugs').item.json.Body || '[]')); } catch(e){ return '[]'; } })() },{ role: 'user', content: 'Generate exactly 30 unique, specific article topics. Return ONLY a JSON array of strings, no other text. Example: [\"topic one\", \"topic two\"]' }] }) }}"
      }
    },
    {
      "id": "tpr-topic-research-parse",
      "name": "Parse Topics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        280,
        300
      ],
      "parameters": {
        "jsCode": "// Parse Groq response and filter against used slugs\nconst response = $('Generate Topics').item.json;\nconst content = response.choices[0].message.content.trim();\n\n// Extract JSON array from response\nlet topics = [];\ntry {\n  const match = content.match(/\\\\[[\\\\s\\\\S]*\\\\]/);\n  topics = JSON.parse(match ? match[0] : content);\n} catch(e) {\n  topics = content.split('\\n').filter(t => t.trim().length > 10).slice(0, 30);\n}\n\n// Get used slugs\nlet usedSlugs = [];\ntry {\n  const raw = $('Read Used Slugs').item.json.Body;\n  usedSlugs = JSON.parse(raw || '[]');\n} catch(e) { usedSlugs = []; }\n\n// Filter out topics whose slug would match a used slug\nfunction toSlug(t) {\n  return t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').substring(0, 60);\n}\n\nconst filtered = topics.filter(t => !usedSlugs.includes(toSlug(t)));\n\nreturn [{\n  json: {\n    topics: filtered.slice(0, 30),\n    count: filtered.length,\n    usedCount: usedSlugs.length,\n    site: 'tpr'\n  }\n}];"
      }
    },
    {
      "id": "tpr-topic-research-save",
      "name": "Save Topics to Minio",
      "type": "n8n-nodes-base.awsS3",
      "typeVersion": 2,
      "position": [
        520,
        300
      ],
      "credentials": {
        "aws": {
          "id": "HdCw5lSb6jwOHLHd",
          "name": "Minio S3"
        }
      },
      "parameters": {
        "operation": "upload",
        "bucketName": "seo-drafts",
        "fileName": "tpr-topics.json",
        "fileContent": "={{ JSON.stringify($json.topics) }}"
      }
    },
    {
      "id": "tpr-topic-research-tg",
      "name": "Telegram Notify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8683132686:AAF5yJ206OcLKsSBx0n4Nm4uBAxcQlRbwyc/sendMessage",
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ JSON.stringify({ chat_id: '-1003919428238', message_thread_id: 5, parse_mode: 'HTML', text: '\ud83d\udccb <b>The Print Route topics uppdaterade</b>\\n\\n<b>Nya topics:</b> ' + $json.count + '\\n<b>Anv\u00e4nda slugs filtrerade:</b> ' + $json.usedCount + '\\n\\nTopics sparade till Minio och redo f\u00f6r generering.' }) }}"
      }
    }
  ],
