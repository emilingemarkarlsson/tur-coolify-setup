  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "telegram-callbacks",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "webhookId": "telegram-callbacks"
    },
    {
      "parameters": {
        "jsCode": "// Parse Telegram callback_query or message\nconst body = $input.first().json.body || $input.first().json;\n\nlet action = null;\nlet slug = null;\nlet site = null;\nlet callbackQueryId = null;\nlet chatId = null;\n\nif (body.callback_query) {\n  const data = body.callback_query.data; // e.g. \"approve:nhl-best-underlying-fla-2026-03-24:thehockeybrain\"\n  const parts = data.split(':');\n  action = parts[0];          // approve | reject\n  slug   = parts[1];          // nhl-best-underlying-fla-2026-03-24\n  site   = parts[2];          // thehockeybrain\n  callbackQueryId = body.callback_query.id;\n  chatId = body.callback_query.message.chat.id;\n} else if (body.message && body.message.text) {\n  // Direct command: /publicera slug site\n  const text = body.message.text.trim();\n  const m = text.match(/^\\/?(publicera|kassera)\\s+(\\S+)(?:\\s+(\\S+))?/);\n  if (m) {\n    action = m[1] === 'publicera' ? 'approve' : 'reject';\n    slug   = m[2];\n    site   = m[3] || 'unknown';\n    chatId = body.message.chat.id;\n  }\n}\n\nif (!action || !slug) {\n  return [{ json: { skip: true, reason: 'no actionable payload' } }];\n}\n\nreturn [{ json: { action, slug, site, callbackQueryId, chatId } }];"
      },
      "id": "parse-callback",
      "name": "Parse Callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.action }}",
              "value2": ""
            }
          ]
        }
      },
      "id": "skip-check",
      "name": "Skip?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.action }}",
              "value2": "approve"
            }
          ]
        }
      },
      "id": "action-check",
      "name": "Approve or Reject?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        900,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://10.0.2.1:9191/publish?slug={{ $json.slug }}&site={{ $json.site }}",
        "options": {}
      },
      "id": "run-publish",
      "name": "Run Publish Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://10.0.2.1:9191/reject?slug={{ $json.slug }}",
        "options": {}
      },
      "id": "run-reject",
      "name": "Kassera Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        320
      ]
    },
    {
      "parameters": {
        "url": "=https://api.telegram.org/bot8683132686:AAF5yJ206OcLKsSBx0n4Nm4uBAxcQlRbwyc/answerCallbackQuery",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "callback_query_id",
              "value": "={{ $('Parse Callback').item.json.callbackQueryId }}"
