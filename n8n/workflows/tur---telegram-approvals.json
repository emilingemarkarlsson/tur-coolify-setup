            {
              "name": "text",
              "value": "={{ $('Parse Callback').item.json.action === 'approve' ? '✅ Publicering startad!' : '❌ Draft kasserad.' }}"
            }
          ]
        },
        "options": {}
      },
      "id": "answer-callback",
      "name": "Answer Callback Query",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
