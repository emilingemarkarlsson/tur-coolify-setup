# Slack app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# Command to run when "Publicera" is clicked. Must contain literal SLUG (replaced with the button value).
# Example (run from host that can ssh to tha):
PUBLISH_CMD=ssh tha 'docker exec $(docker ps -q -f name=openclaw | head -1) /data/.openclaw/scripts/publish-draft.sh SLUG'

# If webhook runs ON the same server as OpenClaw (e.g. Coolify on tha), you can use:
# PUBLISH_CMD=docker exec $(docker ps -q -f name=openclaw | head -1) /data/.openclaw/scripts/publish-draft.sh SLUG

PORT=3000
